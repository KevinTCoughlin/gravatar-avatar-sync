#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Locate the library directory relative to this script so that both the
# in-repo and installed layouts work transparently:
#   In-repo:   bin/gravatar-avatar-sync  →  ../lib/gravatar-avatar-sync/
#   Installed: ~/.local/bin/…            →  ~/.local/lib/gravatar-avatar-sync/
# ---------------------------------------------------------------------------
LIB_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../lib/gravatar-avatar-sync"
if [[ ! -d "$LIB_DIR" ]]; then
  echo "Error: library directory not found: $LIB_DIR" >&2
  exit 1
fi

# shellcheck source=../lib/gravatar-avatar-sync/display.sh
source "$LIB_DIR/display.sh"
# shellcheck source=../lib/gravatar-avatar-sync/identity.sh
source "$LIB_DIR/identity.sh"
# shellcheck source=../lib/gravatar-avatar-sync/fetch.sh
source "$LIB_DIR/fetch.sh"
# shellcheck source=../lib/gravatar-avatar-sync/update.sh
source "$LIB_DIR/update.sh"

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gravatar-avatar-sync"
EMAIL_CONFIG_FILE="$CONFIG_DIR/email"
USERNAME_CONFIG_FILE="$CONFIG_DIR/username"
AVATAR_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/avatars"
AVATAR_BASENAME="gravatar-avatar"
DEFAULT_STYLE="${GRAVATAR_DEFAULT:-mp}"
SIZE="${GRAVATAR_SIZE:-$(detect_avatar_size)}"

# ---------------------------------------------------------------------------
# Load provider (default: gravatar)
# Set GRAVATAR_PROVIDER to the name of a script in lib/providers/ to switch.
# ---------------------------------------------------------------------------
PROVIDER="${GRAVATAR_PROVIDER:-gravatar}"
PROVIDER_SCRIPT="$LIB_DIR/providers/${PROVIDER}.sh"
if [[ ! -f "$PROVIDER_SCRIPT" ]]; then
  echo "Error: provider not found: $PROVIDER (expected $PROVIDER_SCRIPT)" >&2
  exit 1
fi
# shellcheck disable=SC1090
source "$PROVIDER_SCRIPT"

# ---------------------------------------------------------------------------
# Resolve identity
# ---------------------------------------------------------------------------
USERNAME="${GRAVATAR_USERNAME:-}"
EMAIL=""
SOURCE_LABEL=""
resolve_identity "${1:-}"

# ---------------------------------------------------------------------------
# Resolve avatar URL via the active provider
# Sets globals: PROVIDER_URL  SOURCE_LABEL
# ---------------------------------------------------------------------------
PROVIDER_URL=""
"${PROVIDER}_resolve_url" "$USERNAME" "$EMAIL" "$SIZE" "$DEFAULT_STYLE"
URL="$PROVIDER_URL"

# ---------------------------------------------------------------------------
# Fetch and validate
# ---------------------------------------------------------------------------
mkdir -p "$AVATAR_DIR"
TMP_FILE="$(mktemp)"
trap 'rm -f "$TMP_FILE"' EXIT

fetch_avatar "$URL" "$TMP_FILE"
EXT="$(validate_mime "$TMP_FILE")"

# ---------------------------------------------------------------------------
# Write local files and update AccountsService
# ---------------------------------------------------------------------------
FINAL_FILE="${AVATAR_DIR}/${AVATAR_BASENAME}.${EXT}"
write_local_files "$TMP_FILE" "$FINAL_FILE"
update_accounts_service "$FINAL_FILE"

echo "Updated avatar from Gravatar for $SOURCE_LABEL (size=${SIZE})"
